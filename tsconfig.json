{
  "compilerOptions": {
    "paths": {
      "@src/*": ["./src/*"],
      "@math/math.min.js": ["./math/math.min.d.ts"],
      "@math/*": ["./math/*"],
      "@tools/*": ["./tools/*"],
      "@test/*": ["./test/*"]
    },
    "checkJs": true,
    "noEmit": true,
    "lib": ["ES2021", "ESNext.TypedArrays", "dom", "webworker"],
    "types": ["chrome", "node"],
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": false,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "./src/**/*",
    "./math/**/*.d.ts",
    "./tools/**/*",
    "./webstore/**/*.ts",
    "*.config.js",
    "./test/**/*"
  ]
}