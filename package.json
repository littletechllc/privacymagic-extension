{
  "name": "privacymagic",
  "version": "0.0.1",
  "description": "a browser extension that protects your privacy online",
  "main": "index.js",
  "scripts": {
    "audit:ci": "npm audit --audit-level=low",
    "lint": "eslint . --format eslint-formatter-unix && tsc --noEmit",
    "format": "eslint . --fix --format eslint-formatter-unix && tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:i18n": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=test/i18n/",
    "generate:remote-schema": "npx tsx tools/generate-remote-schema.ts",
    "postinstall": "npm run generate:remote-schema",
    "sync:chrome-locale-strings": "npx tsx tools/sync-chrome-locale-string.ts",
    "sync:locale-messages": "npx tsx tools/sync-locale-messages-from-en.ts",
    "webstore:update-listing-descriptions": "npx tsx webstore/update-listing-descriptions.ts",
    "copy": "node tools/copy-src.ts src dist",
    "copy:watch": "npm run copy -- --watch",
    "build:math": "bash math/build.sh",
    "build": "npm run build:math && rm -rf dist && npx tsx tools/filter-list-processor.ts && NODE_ENV=production npm run copy && NODE_ENV=production node esbuild.config.js && web-ext build --source-dir dist --overwrite-dest --artifacts-dir artifacts --filename privacymagic.zip",
    "dev": "concurrently \"npm run copy:watch\" \"NODE_ENV=development node esbuild.config.js watch\" \"web-ext run -t chromium --source-dir dist --ignore-files _metadata _metadata/** privacymagic/**\""
  },
  "author": "Arthur Edelstein",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "dependencies": {
    "psl": "1.15.0",
    "punycode": "2.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.1.34",
    "@types/jest": "30.0.0",
    "@types/punycode": "2.1.4",
    "chokidar": "5.0.0",
    "concurrently": "9.2.1",
    "esbuild": "0.27.2",
    "eslint": "10.0.1",
    "eslint-formatter-unix": "9.0.1",
    "globals": "15.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jsdom": "27.4.0",
    "playwright": "^1.58.2",
    "ts-jest": "29.4.11",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "web-ext": "10.3.0"
  },
  "engines": {
    "node": "24.16.0"
  },
  "overrides": {
    "yauzl": "3.3.0",
    "uuid": "11.1.1"
  }
}
